# ─────────────────────────────────────────────────────────────────────────────
# Instagram Graph API — long-lived user token (valid for 60 days)
# See README.md → "Instagram Token" section for step-by-step generation.
# ─────────────────────────────────────────────────────────────────────────────

# Paste your long-lived access token here.
# Without this, the site renders placeholder "slot" tiles in the feed section.
INSTAGRAM_TOKEN=

# (Optional) Your Instagram user ID — useful for debugging
INSTAGRAM_USER_ID=
